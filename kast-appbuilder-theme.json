{
  "version": "1.0",
  "themeOverrides": {
    "fontFamily": "Inter, Arial, sans-serif",
    "defaultRadius": "6px",
    "primaryColor": "kastNeutral",
    "colors": {
      "kastNeutral": [
        "#f7f7f7",
        "#f0f0f0",
        "#e3e3e3",
        "#cdcdcd",
        "#a8a8a8",
        "#6d6d6d",
        "#4b4b4b",
        "#3d3d3d",
        "#2b2b2b",
        "#1d1d1d"
      ]
    },
    "black": "#2b2b2b",
    "white": "#f0f0f0",
    "fontSizes": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "md": "0.875rem",
      "lg": "1.25rem",
      "xl": "1.5rem"
    },
    "headings": {
      "fontFamily": "Inter, Arial, sans-serif",
      "fontWeight": "600"
    },
    "other": {
      "forceColorScheme": "light",
      "defaultFontWeight": "400",
      "defaultFontWeightMedium": "500",
      "defaultFontWeightBold": "700"
    },
    "components": {
      "AppBuilderTemplateSelector": {
        "defaultProps": {
          "template": "appshell"
        }
      },
      "AppBuilderAppShellTemplatePage": {
        "defaultProps": {
          "navbarBreakpoint": "md",
          "navbarWidth": {
            "base": "100%",
            "md": 360,
            "lg": 360
          },
          "columns": 4,
          "rows": 12,
          "rightColumns": 1,
          "bottomRows": 1,
          "bottomFullWidth": false,
          "rightBorder": false,
          "keepBottomInGrid": false
        }
      },
      "AppBuilderVerticalContainer": {
        "defaultProps": {
          "p": 4,
          "gap": 4
        }
      },
      "AppBuilderContainerWrapper": {
        "defaultProps": {
          "containerThemeOverrides": {
            "appshell": {
              "right": {
                "white": "#f0f0f0",
                "colors": {
                  "gray": [
                    "#f7f7f7",
                    "#f0f0f0",
                    "#e3e3e3",
                    "#cdcdcd",
                    "#a8a8a8",
                    "#6d6d6d",
                    "#4b4b4b",
                    "#3d3d3d",
                    "#2b2b2b",
                    "#1d1d1d"
                  ]
                },
                "components": {
                  "Paper": {
                    "defaultProps": {
                      "withBorder": false,
                      "shadow": "none",
                      "bg": "#f0f0f0"
                    }
                  }
                }
              },
              "bottom": {
                "components": {
                  "Paper": {
                    "defaultProps": {
                      "withBorder": false,
                      "shadow": "none",
                      "bg": "#f0f0f0"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "Paper": {
        "defaultProps": {
          "withBorder": true,
          "shadow": "none",
          "radius": "6px",
          "bg": "#ffffff"
        }
      },
      "Stack": {
        "defaultProps": {
          "gap": 4
        }
      },
      "AppBuilderControlsWidgetComponent": {
        "defaultProps": {
          "stackProps": {
            "gap": 4
          },
          "elementPaperProps": {
            "p": 4,
            "withBorder": false,
            "shadow": "none",
            "radius": "6px",
            "bg": "#f0f0f0"
          }
        }
      },
      "Button": {
        "defaultProps": {
          "variant": "default",
          "radius": "xl",
          "fw": 500,
          "size": "sm"
        }
      },
      "Tabs": {
        "defaultProps": {
          "variant": "default",
          "color": "dark"
        }
      },
      "Text": {
        "defaultProps": {
          "c": "#2b2b2b",
          "fw": 400
        }
      },
      "Switch": {
        "defaultProps": {
          "color": "dark",
          "size": "sm"
        }
      },
      "ViewportIconButton": {
        "defaultProps": {
          "actionIconProps": {
            "size": 24,
            "style": {
              "margin": "0.188rem"
            }
          },
          "iconProps": {
            "style": {
              "width": 12,
              "height": 12
            },
            "strokeWidth": 1.5
          }
        }
      },
      "SelectGridComponent": {
        "defaultProps": {
          "gridProps": {
            "cols": 3,
            "spacing": 4
          },
          "cardProps": {
            "p": 0,
            "px": 0,
            "py": 0,
            "radius": "6px",
            "bg": "#ffffff",
            "style": {
              "--card-selected-color": "#2b2b2b",
              "backgroundColor": "#ffffff"
            }
          },
          "stackProps": {
            "gap": 2
          },
          "imageProps": {
            "fit": "contain",
            "w": "100%",
            "h": "100%",
            "fallbackSrc": "not-found.svg",
            "style": {
              "width": "100%",
              "height": "100%",
              "top": "0",
              "left": "0",
              "objectFit": "contain"
            }
          },
          "labelProps": {
            "size": "xs",
            "fontWeight": "400",
            "ta": "center",
            "style": {
              "textAlign": "center",
              "width": "100%"
            }
          }
        }
      },
      "SelectCarouselComponent": {
        "defaultProps": {
          "carouselProps": {
            "slideGap": 4,
            "slideSize": {
              "base": "33.333333%"
            },
            "emblaOptions": {
              "align": "start",
              "loop": true,
              "slidesToScroll": 1
            }
          },
          "cardProps": {
            "p": 0,
            "px": 0,
            "py": 0,
            "radius": "6px",
            "bg": "#ffffff",
            "style": {
              "--card-selected-color": "#2b2b2b",
              "backgroundColor": "#ffffff"
            }
          },
          "stackProps": {
            "gap": 2
          },
          "imageProps": {
            "fit": "contain",
            "w": "100%",
            "h": "100%",
            "fallbackSrc": "not-found.svg",
            "style": {
              "width": "100%",
              "height": "100%",
              "top": "0",
              "left": "0",
              "objectFit": "contain"
            }
          },
          "labelProps": {
            "size": "xs",
            "fontWeight": "400",
            "ta": "center",
            "style": {
              "textAlign": "center",
              "width": "100%"
            }
          }
        }
      },
      "AppBuilderImage": {
        "defaultProps": {
          "withBorder": false,
          "radius": "6px",
          "fit": "contain",
          "w": "100%",
          "h": "100%"
        }
      },
      "ParameterLabelComponent": {
        "defaultProps": {
          "fontWeight": "500"
        }
      },
      "ParameterSelectComponent": {
        "defaultProps": {
          "componentSettings": {}
        }
      },
      "ViewportBranding": {
        "defaultProps": {
          "light": {
            "backgroundColor": "#e3e3e3"
          }
        }
      },
      "ViewportIcons": {
        "defaultProps": {
          "color": "#2b2b2b",
          "colorDisabled": "#cdcdcd",
          "variant": "subtle",
          "variantDisabled": "transparent",
          "size": 24,
          "iconStyle": {
            "width": 12,
            "height": 12,
            "strokeWidth": 1.5
          }
        }
      },
      "ViewportOverlayWrapper": {
        "defaultProps": {
          "position": "bottom-right"
        }
      }
    }
  }
}
